        <mxCell id="django" parent="django-bg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" value="🐍 Django App Pods (2–3)&#xa;────────────────────&#xa;• ASGI via Daphne / Uvicorn&#xa;• REST API (DRF) — Orgs, Users, Chat&#xa;• Django Channels — WebSocket Consumers&#xa;• JWT Auth (simplejwt)&#xa;• TenantMiddleware → injects org_id&#xa;• OrgScopedManager → filters by org_id" vertex="1">
          <mxGeometry height="170" width="290" x="20" y="45" as="geometry" />
        </mxCell>
        <mxCell id="celery" parent="django-bg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" value="⚙️ Celery Worker Pods&#xa;────────────────────&#xa;• Email on org approval&#xa;• Notifications on chat creation&#xa;• Async side-effects from signals" vertex="1">
          <mxGeometry height="110" width="290" x="340" y="45" as="geometry" />
        </mxCell>
        <mxCell id="signals" parent="django-bg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" value="📡 Django Signals&#xa;────────────────────&#xa;• post_save: Document → publishes to ai:events&#xa;• post_save: Org approved → Celery task&#xa;• post_save: Chat created → notify users" vertex="1">
          <mxGeometry height="110" width="290" x="340" y="175" as="geometry" />
