        <mxCell id="fastapi" parent="fastapi-bg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9c27b0;fontSize=11;align=left;spacingLeft=10;" value="⚡ FastAPI App&#xa;────────────────────&#xa;• Async LLM streaming support&#xa;• Redis Stream consumer (ai:events)&#xa;• Posts agent response back to chat&#xa;• Internal service — not public facing" vertex="1">
          <mxGeometry height="130" width="250" x="20" y="45" as="geometry" />
