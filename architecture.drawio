          <mxGeometry x="800" y="158" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!-- INGRESS -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="ingress" value="🔀 ALB Ingress Controller&#xa;HTTP → REST  |  WebSocket → Django Channels" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="577" y="190" width="500" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ingress" target="django" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!-- CORE SERVICES ROW -->
        <!-- ═══════════════════════════════════════ -->

        <!-- Django Pods -->
        <mxCell id="django" value="🐍 Django App Pods (2–3)&#xa;─────────────────────&#xa;• ASGI via Daphne / Uvicorn&#xa;• REST API (DRF) — Org, Users, Chat&#xa;• Django Channels — WebSocket Consumers&#xa;• JWT Auth (simplejwt)&#xa;• Django Signals → Celery Tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="327" y="310" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- Redis -->
        <mxCell id="redis" value="🔴 Redis&#xa;─────────────────────&#xa;• Streams — chat log per chatID&#xa;  (XADD / XREAD, consumer groups)&#xa;• Channel Layer — WS fan-out across pods&#xa;• Celery Broker — async task queue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="677" y="310" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="postgres" value="🐘 PostgreSQL&#xa;─────────────────────&#xa;• Organisation (name, status, owner)&#xa;• User (org FK, role)&#xa;• AccessGroup (org FK, members)&#xa;• Chat (UUID, org_a, org_b)&#xa;• ChatParticipant (chat FK, user FK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1027" y="310" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- Celery Workers -->
        <mxCell id="celery" value="⚙️ Celery Worker Pods&#xa;─────────────────────&#xa;• Email on org approval&#xa;• Notifications on chat creation&#xa;• Default access group assignment&#xa;• All async side-effects from signals" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="327" y="530" width="300" height="140" as="geometry" />
        </mxCell>

        <!-- Auth Flow -->
        <mxCell id="auth" value="🔐 Auth &amp; Tenant Flow&#xa;─────────────────────&#xa;• Org registers → status: pending&#xa;• App admin approves → approved&#xa;• Org owner creates users (no admin)&#xa;• Owner assigns users → AccessGroup&#xa;• JWT scoped per org / user&#xa;• Cross-tenant: org_a + org_b users" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="677" y="530" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- Pytest -->
        <mxCell id="pytest" value="🧪 Testing (pytest)&#xa;─────────────────────&#xa;• pytest-django — models, views, signals&#xa;• pytest-asyncio — async consumers&#xa;• channels.testing — WebSocket client&#xa;• factory_boy — test data factories&#xa;• Separate test DB (auto-managed)&#xa;• Real Redis for integration tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1027" y="530" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- Edges: Django ↔ Redis ↔ Postgres -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="django" target="redis" parent="1">
